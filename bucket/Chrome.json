{
    "version": "149.0.7827.197",
    "description": "Automatically fetch Google Chrome offline installer using GitHub Actions",
    "homepage": "https://github.com/Bush2021/chrome_installer",
    "license": "MIT",
    "depends": "chrome-plus",
    "notes": "This package acts as a binary provider. It downloads and injects the official Google Chrome binaries directly into the 'rojem/chrome-plus' installation directory. It strictly requires 'chrome-plus' to be installed first.",
    "architecture": {
        "64bit": {
            "url": "https://gh-proxy.org/https://github.com/Bush2021/chrome_installer/releases/download/149.0.7827.197/x64_149.0.7827.197_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "b97671eb6be6f7575c649e45415da050b0beaa5cb5fa60d8eb78fd80bf7202c4"
        },
        "32bit": {
            "url": "https://gh-proxy.org/https://github.com/Bush2021/chrome_installer/releases/download/149.0.7827.197/x86_149.0.7827.197_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "666fcc76b00fc5d5074a8a4cb8f093ab83496dd4568b3fd5225cd85d2f4be4df"
        },
        "arm64": {
            "url": "https://gh-proxy.org/https://github.com/Bush2021/chrome_installer/releases/download/149.0.7827.197/arm64_149.0.7827.197_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "eac5915b27b7dffeb5ede8395dcffcb7713e376168ffe4b5b9e72a282776a60a"
        }
    },
    "bin": "Chrome-bin/chrome.exe",
    "shortcuts": [
        [
            "Chrome-bin/Chrome.exe",
            "Google Chrome"
        ]
    ],
    "persist": [
        "/Data",
        "/Cache"
    ],
    "post_install": [
        "if (-not (Test-Path \"$env:SCOOP\\apps\\chrome-plus\\current\")) { scoop install chrome-plus }",
        "New-Item -ItemType Directory -Force -Path \"$dir\\Data\" | Out-Null",
        "New-Item -ItemType Directory -Force -Path \"$dir\\Cache\" | Out-Null",
        "if (Test-Path \"$env:SCOOP\\apps\\chrome-plus\\current\\version.dll\") { Copy-Item -Path \"$env:SCOOP\\apps\\chrome-plus\\current\\version.dll\" -Destination \"$dir\\Chrome-bin\\\" -Force }",
        "if (Test-Path \"$env:SCOOP\\apps\\chrome-plus\\current\\chrome++.ini\") { Copy-Item -Path \"$env:SCOOP\\apps\\chrome-plus\\current\\chrome++.ini\" -Destination \"$dir\\Chrome-bin\\\" -Force }"
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://gh-proxy.org/https://github.com/Bush2021/chrome_installer/releases/download/$version/x64_$version_chrome_installer_uncompressed.exe#/dl.7z"
            },
            "32bit": {
                "url": "https://gh-proxy.org/https://github.com/Bush2021/chrome_installer/releases/download/$version/x86_$version_chrome_installer_uncompressed.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://gh-proxy.org/https://github.com/Bush2021/chrome_installer/releases/download/$version/arm64_$version_chrome_installer_uncompressed.exe#/dl.7z"
            }
        }
    }
}
